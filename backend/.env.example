# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRATION_HOURS=24

# Admin Credentials
# Generate hash using: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewY5GyYqgdW.Qeou

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# Data Directory
DATA_DIR=./data

# Backup Settings
BACKUP_ENABLED=True
BACKUP_RETENTION_DAYS=30
