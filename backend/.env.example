# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py
FLASK_SECRET_KEY=change-this-to-a-secure-random-string

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# Admin Initialization (Set ONE of these)
# Option 1: Plain text password (recommended for simplicity)
ADMIN_PASSWORD=your-secure-admin-password
# Option 2: Pre-hashed password (for advanced use)
# ADMIN_PASSWORD_HASH=$2b$12$....

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5000,http://your-intranet-domain.com
